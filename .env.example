# PostgreSQL connection string — Railway auto-fills this if you link the Postgres service
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT secret — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_here

# Admin credentials (used to create default admin on first run)
ADMIN_USER=admin
ADMIN_PASS=admin123

# Set to production on Railway
NODE_ENV=production
